# ──────────────────────────────────────────────────────────────
#  Agentic Travel AI Planner — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────

# ── OpenAI ────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...

# ── PostgreSQL ────────────────────────────────────────────────
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<dbname>
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/travel_ai_db

# ── Application ───────────────────────────────────────────────
APP_ENV=development          # development | production
SECRET_KEY=change-me-in-production
DEBUG=true

# Comma-separated list of allowed frontend origins (CORS)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── RAG / Vector Store ────────────────────────────────────────
VECTORSTORE_PATH=./data/vectorstore
EMBEDDING_MODEL=text-embedding-3-small
# Number of document chunks to retrieve per query
RAG_TOP_K=5

# ── LLM ──────────────────────────────────────────────────────
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=4096

# ── Agent ─────────────────────────────────────────────────────
AGENT_MAX_RETRIES=2
